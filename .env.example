# =============================================================================
# .env.example — required environment variables for FirstClub Membership Program
#
# Copy this file to .env for local overrides (git-ignored).
# In production, supply these via your deployment platform's secret management
# (e.g., AWS Secrets Manager, Kubernetes Secrets, Railway env vars).
# =============================================================================

# ─── Spring Profile ───────────────────────────────────────────────────────────
# REQUIRED in staging/production. Activates the correct datasource, Flyway,
# and security settings. Use "prod" for both staging and production deployments.
# Example: SPRING_PROFILES_ACTIVE=prod
# Required in staging: yes | Required in production: yes
SPRING_PROFILES_ACTIVE=prod

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED in production/staging. Must be a Base64-encoded random 256-bit (32-byte) key.
# Generate with:  openssl rand -base64 32
# Required in staging: yes | Required in production: yes
JWT_SECRET=<replace-with-openssl-rand-base64-32-output>

# Optional overrides (defaults are in application.properties)
# JWT_EXPIRATION_MS=86400000       # 24 hours
# JWT_REFRESH_EXPIRATION_MS=604800000  # 7 days

# ─── PII Encryption ───────────────────────────────────────────────────────────
# REQUIRED in staging/production. 256-bit AES key for encrypting customer PII
# (names, emails, phones). Application will refuse to start if not set when
# SPRING_PROFILES_ACTIVE is not "dev" or "test".
# Generate with:  openssl rand -base64 32
# Required in staging: yes | Required in production: yes
PII_ENC_KEY=<replace-with-openssl-rand-base64-32-output>

# ─── Database (production / staging only) ─────────────────────────────────────
# REQUIRED in staging/production. Dev uses H2 in-memory — no DB env vars needed
# for local development. All three must be set; there are no fallback defaults.
# Required in staging: yes | Required in production: yes
DATABASE_URL=jdbc:postgresql://localhost:5432/membershipdb
DATABASE_USERNAME=membership_user
DATABASE_PASSWORD=<replace-with-strong-password>

# ─── Webhook HMAC secret ──────────────────────────────────────────────────────
# REQUIRED in staging/production. HMAC secret for verifying signed webhook
# payloads from the payment gateway. Application will refuse to start if the
# dev placeholder is detected when SPRING_PROFILES_ACTIVE is not "dev" or "test".
# Required in staging: yes | Required in production: yes
WEBHOOK_SECRET=<replace-with-strong-random-secret>

# ─── Swagger ──────────────────────────────────────────────────────────────────
# Overrides the server URL shown on the Swagger UI "Servers" dropdown.
# Useful when running behind a reverse proxy or in a staging environment.
# Swagger UI is disabled when SPRING_PROFILES_ACTIVE=prod.
# Required in staging: no | Required in production: no
# APP_SWAGGER_LOCAL_URL=https://staging.firstclub.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for your frontend.
# Defaults to https://yourapp.com in prod profile if not set.
# Required in staging: yes | Required in production: yes
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
