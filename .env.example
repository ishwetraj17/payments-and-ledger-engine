# =============================================================================
# .env.example — required environment variables for FirstClub Membership Program
#
# Copy this file to .env for local overrides (git-ignored).
# In production, supply these via your deployment platform's secret management
# (e.g., AWS Secrets Manager, Kubernetes Secrets, Railway env vars).
# =============================================================================

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED in production. Must be a Base64-encoded random 256-bit (32-byte) key.
# Generate with:  openssl rand -base64 32
JWT_SECRET=<replace-with-openssl-rand-base64-32-output>

# Optional overrides (defaults are in application.properties)
# JWT_EXPIRATION_MS=86400000       # 24 hours
# JWT_REFRESH_EXPIRATION_MS=604800000  # 7 days

# ─── PII Encryption ───────────────────────────────────────────────────────────
# REQUIRED in production. 256-bit AES key for encrypting customer PII (names, emails, phones).
# If not set, the application falls back to an all-zero dev key and logs a WARNING.
# Generate with:  openssl rand -base64 32
PII_ENC_KEY=<replace-with-openssl-rand-base64-32-output>

# ─── Database (production / staging only) ─────────────────────────────────────
# Dev uses H2 in-memory — no DB env vars needed for local development.
DATABASE_URL=jdbc:postgresql://localhost:5432/membershipdb
DATABASE_USERNAME=membership_user
DATABASE_PASSWORD=<replace-with-strong-password>

# ─── Webhook HMAC secret ──────────────────────────────────────────────────────
# REQUIRED in production. HMAC secret for verifying signed webhook payloads from the payment gateway.
# The default dev value ("dev-only-webhook-secret-change-in-prod") must NOT be used in production.
# Override via the payments.webhook.secret property or inject directly from your secret manager.
WEBHOOK_SECRET=<replace-with-strong-random-secret>

# ─── Swagger ──────────────────────────────────────────────────────────────────
# Overrides the server URL shown on the Swagger UI "Servers" dropdown.
# Useful when running behind a reverse proxy or in a staging environment.
# APP_SWAGGER_LOCAL_URL=https://staging.firstclub.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for your frontend
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
